# ── Application ───────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
LOG_LEVEL=INFO

# ── Admin Auth ────────────────────────────────────────
# Generate hash: python scripts/hash_password.py
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$changeme_run_scripts_hash_password_py

# ── Backend ───────────────────────────────────────────
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173

# ── Frontend ──────────────────────────────────────────
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000

# ── PostgreSQL ────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=aarogyashield
POSTGRES_USER=aarogya
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_SESSION_TTL=86400

# ── Qdrant ────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=policies

# ── LLM (Google) ──────────────────────────────────────
GOOGLE_API_KEY=your_google_ai_studio_key
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3

# ── Embeddings ────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
