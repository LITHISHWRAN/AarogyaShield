# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/

# Distribution / packaging
*.egg-info/
dist/
build/

# Test artefacts
.pytest_cache/
.coverage
htmlcov/

# Type checker / linter caches
.mypy_cache/
.ruff_cache/

# Secrets — never copy into the image
.env
.env.*
!.env.example

# Editor and OS files
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Logs
*.log

# Hugging Face model cache — large, mounted as a volume in dev
# baked into the image in production via RUN in Dockerfile
.cache/

# Git
.git/
.gitignore
.gitattributes
